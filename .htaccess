# Desactivar la vista de directorios (Seguridad BIOR Web Studio)
Options -Indexes

# Forzar conexión segura HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Desactivar la vista de directorios (Seguridad BIOR Web Studio)
Options -Indexes

# Forzar conexi贸n segura HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ======================================================================
# CACHÉ DEL NAVEGADOR (Browser Caching) PARA MEJORAR LCP Y PERFORMANCE
# ======================================================================

<IfModule mod_expires.c>
    # Activar el módulo de expiración
    ExpiresActive On
    
    # 1. Imágenes y Videos (1 año) - Rara vez cambian
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 year"
    
    # 2. Fuentes, Favicons e Íconos (1 año)
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    
    # 3. CSS y JavaScript (1 mes) - Por si haces actualizaciones en la agencia
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # 4. HTML (No se cachea o se hace por muy poco tiempo para que vean los cambios)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Forzar la cabecera Cache-Control para asegurar que Google lo detecte
<IfModule mod_headers.c>
    # Asignar caché pública a los archivos estáticos
    <FilesMatch "\.(jpg|jpeg|png|webp|svg|gif|mp4|webm|css|js|woff2|ico)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>